# Copy this file to `secrets.toml` in the same folder (`.streamlit/`).
# Never commit `secrets.toml` — it is listed in `frontend/.gitignore`.
#
# Get a key: https://aistudio.google.com/apikey (Google AI Studio)

GOOGLE_API_KEY = "paste-your-google-api-key-here"

# Optional: use this name instead of GOOGLE_API_KEY if you prefer
